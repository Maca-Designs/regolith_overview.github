					}
				}
			},
			{
				"condition": "!q.block_state('maca_ve:connect_north') && !q.block_state('maca_ve:connect_south') && q.block_state('maca_ve:connect_east') && !q.block_state('maca_ve:connect_west')",
				"components": {
					"minecraft:collision_box": {
						"origin": [
							-8,
							0,
							-1
						],
						"size": [
							9,
