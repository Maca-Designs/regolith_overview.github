{
    "$files": {
        "array": "{{blocks.filter(x => x?.slab)}} + slabs",
        "fileName": "{{name}}_slab_half"
    },
    "$template": {
	"pools": [
	  {
		"rolls": 1,
		"entries": [
		  {
			"type": "item",
			"name": "maca_templ:{{name}}_slab",
			"weight": 1,
			"functions": [
			  {
				"function": "set_count",
				"count": 1
			  }
			]
		  }
		]
	  }
	]
  }
}