{
    "format_version": "1.12.0",
    "animation_controllers": {
        "controller.animation.maca_templ.entity.move": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "idle"
                    ],
                    "transitions": [
                        {
                            "walk": "query.modified_move_speed > 0.1"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "walk": {
                    "animations": [
                        "walk"
                    ],
                    "transitions": [
                        {
                            "default": "query.modified_move_speed < 0.1"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        }
    }
}